+      }
+    );
+  })();
+  schemaBootstrapPromises.set(runtime, bootstrap);
+  try {
+    await bootstrap;
+  } catch (error) {
+    schemaBootstrapPromises.delete(runtime);
+    throw error;
+  }
+}
+async function getDb(runtime) {
+  await ensureTodoSchema(runtime);
+  return requireDb(runtime);
+}
 
